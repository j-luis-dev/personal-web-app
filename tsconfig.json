{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "src/**/*", "tests/**/*", "vitest.config.ts", "playwright.config.ts"],
  "exclude": ["dist", "public", "node_modules", "playwright-report", "test-results"],
  "compilerOptions": {
    "plugins": [{ "name": "@astrojs/ts-plugin" }],
    "paths": {
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"]
    }
  }
}
