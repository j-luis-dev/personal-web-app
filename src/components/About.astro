---
import portrait from '../assets/Iam.webp';
import { about, sections } from '../data/portfolio';
---

<section class="py-[clamp(48px,8vw,var(--gap-2xl))] border-t border-border section-handoff" id="about" data-od-id="about">
  <div class="about-handoff-bg" aria-hidden="true" data-od-id="about-handoff-bg"></div>
  <div class="site-container">
    <div class="grid grid-cols-[280px_minmax(0,1fr)] items-start gap-[var(--gap-xl)] max-[920px]:grid-cols-1">
      <figure class="forest-panel reveal m-0 w-full max-w-[280px] p-2.5 max-[920px]:mx-auto max-[920px]:max-w-[min(280px,100%)]" data-od-id="about-photo-wrap">
        <img
          class="about-photo"
          src={portrait.src}
          alt={about.portraitAlt}
          width="560"
          height="560"
          data-od-id="about-photo"
        />
      </figure>
      <div class="forest-panel p-[clamp(24px,3.5vw,32px)] reveal-stagger">
        <p class="eyebrow text-rise" style="--rise-i: 0">{sections.about.eyebrow}</p>
        <h2 class="text-rise" style="--rise-i: 1" data-od-id="about-heading">{sections.about.heading}</h2>
        <p class="lead text-rise" style="margin-top: 20px; --rise-i: 2" data-od-id="about-bio">
          {about.bio}
        </p>
        <dl class="mt-[var(--gap-lg)] pt-[var(--gap-lg)] border-t border-border flex flex-col gap-[var(--gap-sm)] text-rise" style="--rise-i: 3" data-od-id="about-education">
          <div>
            <dt class="font-mono text-[11px] tracking-[0.06em] uppercase text-muted">{about.education.label}</dt>
            <dd class="m-0 mb-[var(--gap-sm)] text-[15px] text-fg">{about.education.value}</dd>
          </div>
          <div>
            <dt class="font-mono text-[11px] tracking-[0.06em] uppercase text-muted">{about.languages.label}</dt>
            <dd class="m-0 mb-[var(--gap-sm)] text-[15px] text-fg">{about.languages.value}</dd>
          </div>
        </dl>
        <div class="text-rise" style="--rise-i: 4" data-od-id="skills-section">
          <p class="meta mt-[var(--gap-lg)] mb-0">Skills</p>
          <div class="mt-[var(--gap-md)] flex flex-wrap gap-2">
            {about.skills.map((skill, index) => (
              <span class="tag" style={`--tag-i: ${index}`}>{skill}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
