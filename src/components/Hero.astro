---
import { site } from '../data/portfolio';
---

<section class="hero section-handoff" data-od-id="hero">
  <svg class="hero-filters" aria-hidden="true" focusable="false" width="0" height="0">
    <defs>
      <filter id="hero-grain" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence type="fractalNoise" baseFrequency="0.75" numOctaves="4" stitchTiles="stitch" result="noise"/>
        <feColorMatrix in="noise" type="saturate" values="0" result="mono"/>
        <feBlend in="SourceGraphic" in2="mono" mode="soft-light"/>
      </filter>
    </defs>
  </svg>
  <div class="hero-ambient" aria-hidden="true" data-od-id="hero-ambient">
    <div class="hero-ambient-gradient"></div>
    <div class="hero-ambient-orbs">
      <span class="hero-orb hero-orb--warm-tr"></span>
      <span class="hero-orb hero-orb--green-bl"></span>
      <span class="hero-orb hero-orb--depth"></span>
    </div>
    <div class="hero-ambient-grain"></div>
  </div>
  <div class="hero-handoff-bridge" aria-hidden="true" data-od-id="hero-work-bridge"></div>
  <div class="site-container hero-split">
    <div class="hero-copy">
      <p class="eyebrow hero-rise" style="--rise-delay: 40ms">{site.eyebrow}</p>
      <h1 class="h1 hero-rise-lines" data-od-id="hero-headline">
        <span class="hero-rise hero-rise-line" style="--rise-delay: 80ms">{site.name.first}</span><br>
        <span class="hero-rise hero-rise-line" style="--rise-delay: 160ms">{site.name.last}</span>
      </h1>
      <p class="hero-role hero-rise" style="--rise-delay: 240ms">{site.role}</p>
      <p class="lead hero-rise" style="margin-top: 20px; --rise-delay: 320ms" data-od-id="hero-tagline">{site.tagline}</p>
      <div class="hero-cta hero-rise" style="--rise-delay: 400ms">
        <a
          href={site.ctas.primary.href}
          class="btn-base btn-accent-fill hover:bg-[var(--accent-hover)] focus-visible:bg-[var(--accent-hover)]"
          data-od-id="hero-cta-primary"
        >{site.ctas.primary.label}</a>
        <a
          href={site.ctas.secondary.href}
          class="btn-base border-border bg-transparent text-fg after:content-['→'] after:transition-transform after:duration-200 hover:border-accent hover:after:translate-x-0.5 focus-visible:border-accent"
          data-od-id="hero-cta-secondary"
        >{site.ctas.secondary.label}</a>
      </div>
    </div>
    <div class="mascot-stage forest-panel hero-mascot-enter" data-od-id="hero-mascot" aria-label="Forest guide — 3D character">
      <span class="hero-orb hero-orb--local" aria-hidden="true"></span>
      <div class="mascot-glow" aria-hidden="true"></div>
      <canvas id="hero-3d-canvas" aria-label="Meshy AI Pet — forest guide"></canvas>
    </div>
  </div>
</section>

<script>
  import '../scripts/hero-scene.ts';
</script>
