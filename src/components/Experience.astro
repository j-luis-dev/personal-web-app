---
import PortfolioFadeText from './PortfolioFadeText.astro';
import { experience, sections } from '../data/portfolio';
---

<section class="py-[clamp(48px,8vw,var(--gap-2xl))] bg-surface border-y border-border" id="experience" data-od-id="experience">
  <div class="site-container">
    <div class="max-w-[40ch] mb-10">
      <PortfolioFadeText as="p" class="eyebrow" enhance delay={0}>
        {sections.experience.eyebrow}
      </PortfolioFadeText>
      <PortfolioFadeText as="h2" class="section-heading" enhance delay={0.08} data-od-id="experience-heading">
        {sections.experience.heading}
      </PortfolioFadeText>
    </div>
    <div class="flex flex-col gap-[var(--gap-md)]">
      {experience.map((entry) =>
        entry.kind === 'timeline' ? (
          <div
            class="grid grid-cols-[140px_1fr] items-start gap-[var(--gap-lg)] max-[720px]:grid-cols-1 max-[720px]:gap-[var(--gap-xs)] forest-panel p-[clamp(20px,3vw,26px)] reveal"
            style={`--reveal-delay: ${entry.revealDelay}`}
            data-od-id={entry.id}
          >
            <div class="meta num">{entry.period}</div>
            <div>
              <h3 class="font-display text-[19px] mb-1">{entry.company}</h3>
              <p class="text-muted text-[15px] m-0">{entry.role}</p>
              <p class="text-muted text-[15px] mt-2 mb-0 max-w-[58ch]">{entry.detail}</p>
            </div>
          </div>
        ) : (
          <div
            class="forest-panel p-[clamp(16px,2.5vw,22px)] reveal text-muted text-[14px] leading-[1.55]"
            style={`--reveal-delay: ${entry.revealDelay}`}
            data-od-id={entry.id}
          >
            {entry.entries.map((item, index) => (
              <>
                {index > 0 && <>&nbsp;·&nbsp;</>}
                <strong style="color: var(--fg); font-weight: 500;">{item.company}</strong>
                {' · '}
                {item.role}
                {' · '}
                {item.period}
                {' — '}
                {item.detail}
              </>
            ))}
          </div>
        ),
      )}
    </div>
  </div>
</section>
